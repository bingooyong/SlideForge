# ============== 必填 ==============
# Gemini API Key（PDF 版面 OCR 必需）
# 获取： https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ============== 上传与存储 ==============
# 上传与任务文件根目录（会在此下创建 tasks/<task_id>/）
UPLOAD_DIR=./uploads
# 单文件最大字节数（默认 50MB）
MAX_FILE_SIZE=52428800
# 允许的扩展名（逗号分隔，小写）
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,webp,bmp

# ============== 可选 - Gemini ==============
# 版面分析模型（免费层：Gemini 2 Flash 为 0 额度，请用 gemini-2.5-flash，约 5 RPM / 20 RPD）
GEMINI_LAYOUT_MODEL=gemini-2.5-flash
# 每分钟请求上限（免费层 2.5 Flash 为 5，建议设为 5 避免 429）
GEMINI_MAX_RPM=5

# ============== 可选 - 服务 ==============
# CORS 允许源（* 表示任意）
CORS_ORIGINS=*
# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
# Uvicorn 工作进程数
WORKERS=2
# 单任务超时秒数
TASK_TIMEOUT=3600
# Pipeline 每任务最大并发页数
PIPELINE_MAX_WORKERS=3
